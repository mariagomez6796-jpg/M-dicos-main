# Application Configuration
APP_NAME=chat-api
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8004
WORKERS=4

# Database Configuration - MySQL
DB_HOST=mysql
DB_PORT=3306
DB_NAME=vitalapp_chat
DB_USER=root
DB_PASSWORD=rootpassword
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
WEBSOCKET_MAX_CONNECTIONS_PER_USER=5
WEBSOCKET_MESSAGE_MAX_SIZE=10000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# External Services
APPOINTMENTS_API_URL=http://appointments-api:8001
APPOINTMENTS_API_TIMEOUT=10
AUTH_SERVICE_URL=http://vitalapp-auth:3000
AUTH_SERVICE_TIMEOUT=5

# Conversation Configuration
CONVERSATION_EXPIRY_DAYS=14
CONVERSATION_CLEANUP_INTERVAL_HOURS=24
MESSAGE_RETENTION_DAYS=365

# File Upload (Future)
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Monitoring & Logging
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics